jinx_name: focus_pane
description: Focus an existing pane by its ID, bringing it to the foreground
inputs:
  - paneId:
      type: string
      description: The ID of the pane to focus
      required: true
steps:
  - name: focus_pane
    engine: incognide
    action: focus_pane
    args:
      paneId: "{{ paneId }}"
