jinx_name: navigate_browser
description: Navigate a browser pane to a URL
inputs:
  - paneId:
      type: string
      description: The ID of the browser pane
      required: true
  - url:
      type: string
      description: The URL to navigate to
      required: true
steps:
  - name: navigate_browser
    engine: incognide
    action: navigate_pane
    args:
      paneId: "{{ paneId }}"
      target: "{{ url }}"
