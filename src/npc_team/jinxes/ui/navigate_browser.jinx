jinx_name: navigate_browser
description: Navigate a browser pane to a URL
permissions:
  default: allow
inputs:
  - paneId:
      type: string
      description: The ID of the browser pane (omit for active)
      required: false
  - url:
      type: string
      description: The URL to navigate to
      required: true
steps:
  - name: navigate_browser
    engine: incognide
    action: navigate_pane
    args:
      paneId: "{{ paneId | default('active') }}"
      target: "{{ url }}"
