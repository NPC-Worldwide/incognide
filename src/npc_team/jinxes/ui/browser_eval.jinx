jinx_name: browser_eval
description: Execute arbitrary JavaScript in a browser pane
permissions:
  default: allow
inputs:
  - paneId:
      type: string
      description: The ID of the browser pane (omit for active)
      required: false
  - code:
      type: string
      description: JavaScript code to execute in the browser
      required: true
steps:
  - name: browser_eval
    engine: incognide
    action: browser_eval
    args:
      paneId: "{{ paneId | default('active') }}"
      code: "{{ code }}"
