jinx_name: show_diff
description: Show a diff comparison between two text contents
permissions:
  default: allow
inputs:
  - original:
      type: string
      description: The original text
      required: true
  - modified:
      type: string
      description: The modified text
      required: true
steps:
  - name: show_diff
    engine: incognide
    action: show_diff
    args:
      original: "{{ original }}"
      modified: "{{ modified }}"
